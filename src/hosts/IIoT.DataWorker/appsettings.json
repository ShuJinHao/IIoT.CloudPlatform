{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "DistributedLock": {
    "LeaseSeconds": 120,
    "RenewalCadenceSeconds": 30
  },
  "CacheSafety": {
    "FailSafeMinutes": 30
  },
  "Seq": {
    "Enabled": false,
    "ServerUrl": "",
    "ApiKey": ""
  },
  "Infrastructure": {
    "Postgres": {
      "EnableRetry": false,
      "CommandTimeoutSeconds": 30,
      "MaxRetryCount": 3,
      "MaxRetryDelaySeconds": 10
    },
    "EventBus": {
      "ConcurrentMessageLimit": 4,
      "PrefetchMultiplier": 4,
      "MinimumPrefetchCount": 4,
      "RetryLimit": 3,
      "RetryInitialSeconds": 1,
      "RetryIncrementSeconds": 2,
      "HostStartTimeoutSeconds": 30,
      "HostStopTimeoutSeconds": 30,
      "EndpointPrefix": "",
      "Consumers": {
        "PassStationConcurrentMessageLimit": 4,
        "DeviceLogConcurrentMessageLimit": 3,
        "HourlyCapacityConcurrentMessageLimit": 1
      }
    }
  },
  "Outbox": {
    "BatchSize": 20,
    "PollingIntervalSeconds": 5
  }
}
