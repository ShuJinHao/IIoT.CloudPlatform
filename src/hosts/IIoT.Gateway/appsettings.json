{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "Seq": {
    "Enabled": false,
    "ServerUrl": "",
    "ApiKey": ""
  },
  "ReverseProxy": {
    "Routes": {
      "human": {
        "ClusterId": "httpapi",
        "Order": 100,
        "Match": {
          "Path": "/api/v1/human/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-IIoT-Route-Surface",
            "Set": "human"
          }
        ]
      },
      "edge": {
        "ClusterId": "httpapi",
        "Order": 100,
        "Match": {
          "Path": "/api/v1/edge/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-IIoT-Route-Surface",
            "Set": "edge"
          }
        ]
      },
      "bootstrap-device-instance": {
        "ClusterId": "httpapi",
        "Match": {
          "Path": "/api/v1/bootstrap/device-instance"
        },
        "Transforms": [
          {
            "PathSet": "/api/v1/edge/bootstrap/device-instance"
          },
          {
            "RequestHeader": "X-IIoT-Route-Surface",
            "Set": "bootstrap"
          }
        ]
      },
      "bootstrap-edge-login": {
        "ClusterId": "httpapi",
        "Match": {
          "Path": "/api/v1/bootstrap/edge-login"
        },
        "Transforms": [
          {
            "PathSet": "/api/v1/human/identity/edge-login"
          },
          {
            "RequestHeader": "X-IIoT-Route-Surface",
            "Set": "bootstrap"
          }
        ]
      },
      "bootstrap-edge-refresh": {
        "ClusterId": "httpapi",
        "Match": {
          "Path": "/api/v1/bootstrap/edge-refresh"
        },
        "Transforms": [
          {
            "PathSet": "/api/v1/edge/bootstrap/edge-refresh"
          },
          {
            "RequestHeader": "X-IIoT-Route-Surface",
            "Set": "bootstrap"
          }
        ]
      },
      "legacy-edge-bootstrap-device-instance": {
        "ClusterId": "httpapi",
        "Match": {
          "Path": "/api/v1/edge/bootstrap/device-instance"
        },
        "Transforms": [
          {
            "RequestHeader": "X-IIoT-Deprecated-Alias",
            "Set": "true"
          },
          {
            "RequestHeader": "X-IIoT-Route-Surface",
            "Set": "legacy-bootstrap-alias"
          }
        ]
      },
      "legacy-human-edge-login": {
        "ClusterId": "httpapi",
        "Match": {
          "Path": "/api/v1/human/identity/edge-login"
        },
        "Transforms": [
          {
            "RequestHeader": "X-IIoT-Deprecated-Alias",
            "Set": "true"
          },
          {
            "RequestHeader": "X-IIoT-Route-Surface",
            "Set": "legacy-edge-login-alias"
          }
        ]
      }
    },
    "Clusters": {
      "httpapi": {
        "Destinations": {
          "primary": {
            "Address": "http://localhost:8080/"
          }
        }
      }
    }
  }
}
