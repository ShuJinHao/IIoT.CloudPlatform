{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "Seq": {
    "Enabled": false,
    "ServerUrl": "",
    "ApiKey": ""
  },
  "GatewayRoutes": {
    "BlockedAliases": {
      "blocked-edge-bootstrap": {
        "PathPrefix": "/api/v1/edge/bootstrap",
        "RouteSurface": "blocked-bootstrap-alias"
      },
      "blocked-human-edge-login": {
        "Path": "/api/v1/human/identity/edge-login",
        "RouteSurface": "blocked-bootstrap-alias"
      }
    }
  },
  "ReverseProxy": {
    "Routes": {
      "internal-healthz": {
        "ClusterId": "httpapi",
        "Order": 0,
        "Match": {
          "Path": "/internal/healthz"
        },
        "Transforms": [
          {
            "RequestHeader": "X-IIoT-Route-Surface",
            "Set": "internal-health"
          }
        ]
      },
      "oidc-discovery": {
        "ClusterId": "httpapi",
        "Order": 10,
        "Match": {
          "Path": "/.well-known/openid-configuration"
        },
        "Transforms": [
          {
            "RequestHeader": "X-IIoT-Route-Surface",
            "Set": "oidc"
          }
        ]
      },
      "oidc-connect": {
        "ClusterId": "httpapi",
        "Order": 10,
        "Match": {
          "Path": "/connect/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-IIoT-Route-Surface",
            "Set": "oidc"
          }
        ]
      },
      "human": {
        "ClusterId": "httpapi",
        "Order": 100,
        "Match": {
          "Path": "/api/v1/human/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-IIoT-Route-Surface",
            "Set": "human"
          }
        ]
      },
      "edge": {
        "ClusterId": "httpapi",
        "Order": 100,
        "Match": {
          "Path": "/api/v1/edge/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-IIoT-Route-Surface",
            "Set": "edge"
          }
        ]
      },
      "ai-read": {
        "ClusterId": "httpapi",
        "Order": 100,
        "Match": {
          "Path": "/api/v1/ai/read/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-IIoT-Route-Surface",
            "Set": "ai-read"
          }
        ]
      },
      "ai-identity": {
        "ClusterId": "httpapi",
        "Order": 100,
        "Match": {
          "Path": "/api/v1/ai/identity/{**catch-all}"
        },
        "Transforms": [
          {
            "RequestHeader": "X-IIoT-Route-Surface",
            "Set": "ai-identity"
          }
        ]
      },
      "bootstrap-device-instance": {
        "ClusterId": "httpapi",
        "Match": {
          "Path": "/api/v1/bootstrap/device-instance"
        },
        "Transforms": [
          {
            "PathSet": "/api/v1/edge/bootstrap/device-instance"
          },
          {
            "RequestHeader": "X-IIoT-Route-Surface",
            "Set": "bootstrap"
          }
        ]
      },
      "bootstrap-edge-login": {
        "ClusterId": "httpapi",
        "Match": {
          "Path": "/api/v1/bootstrap/edge-login"
        },
        "Transforms": [
          {
            "PathSet": "/api/v1/human/identity/edge-login"
          },
          {
            "RequestHeader": "X-IIoT-Route-Surface",
            "Set": "bootstrap"
          }
        ]
      },
      "bootstrap-edge-refresh": {
        "ClusterId": "httpapi",
        "Match": {
          "Path": "/api/v1/bootstrap/edge-refresh"
        },
        "Transforms": [
          {
            "PathSet": "/api/v1/edge/bootstrap/edge-refresh"
          },
          {
            "RequestHeader": "X-IIoT-Route-Surface",
            "Set": "bootstrap"
          }
        ]
      }
    },
    "Clusters": {
      "httpapi": {
        "HttpRequest": {
          "ActivityTimeout": "00:01:00"
        },
        "HealthCheck": {
          "Active": {
            "Enabled": true,
            "Interval": "00:00:10",
            "Timeout": "00:00:05",
            "Policy": "ConsecutiveFailures",
            "Path": "/internal/healthz"
          }
        },
        "Destinations": {
          "primary": {
            "Address": "http://localhost:8080/"
          }
        }
      }
    }
  }
}
