{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "CacheSafety": {
    "FailSafeMinutes": 30
  },
  "Infrastructure": {
    "Postgres": {
      "EnableRetry": false,
      "CommandTimeoutSeconds": 30,
      "MaxRetryCount": 3,
      "MaxRetryDelaySeconds": 10
    }
  }
}
