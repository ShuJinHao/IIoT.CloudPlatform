{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Secret": "",
    "ExpiryMinutes": 60,
    "Issuer": "IIoT.CloudPlatform",
    "Audience": "IIoT.WpfClient"
  },
  "DistributedLock": {
    "LeaseSeconds": 120,
    "RenewalCadenceSeconds": 30,
    "OperationTimeoutMilliseconds": 5000,
    "RenewalShutdownTimeoutMilliseconds": 5000
  },
  "Seq": {
    "Enabled": false,
    "ServerUrl": "",
    "ApiKey": ""
  },
  "RefreshTokens": {
    "HumanTtlDays": 7,
    "EdgeBootstrapTtlDays": 30,
    "HumanMaxActiveSessions": 3
  },
  "OidcProvider": {
    "Issuer": "http://localhost:8080",
    "AllowIntranetHttpOidc": false,
    "AicopilotClientId": "aicopilot",
    "AicopilotRedirectUris": [
      "http://127.0.0.1:5178/api/identity/cloud-oidc/callback",
      "http://localhost:5178/api/identity/cloud-oidc/callback"
    ],
    "AicopilotPostLogoutRedirectUris": [
      "http://127.0.0.1:5178/login",
      "http://localhost:5178/login"
    ],
    "AuthorizationCodeLifetimeMinutes": 5,
    "AccessTokenLifetimeMinutes": 10,
    "IdentityTokenLifetimeMinutes": 10,
    "SessionIdleMinutes": 30,
    "SessionCookieName": "__Host-IIoT-OidcSession"
  },
  "AiRead": {
    "MaxRows": 100,
    "MaxTimeRangeDays": 30,
    "MaxLogMessageLength": 500
  },
  "EdgeInstallerArtifacts": {
    "RootPath": "edge-updates/installers"
  },
  "EdgeRelease": {
    "MaxVersionsPerComponent": 3
  },
  "EdgeReleaseUpload": {
    "MaxUploadMbps": 1000,
    "MaxBundleBytes": 2147483648,
    "StagingDirectoryName": ".staging"
  },
  "CacheSafety": {
    "FailSafeMinutes": 30
  },
  "Infrastructure": {
    "Postgres": {
      "EnableRetry": false,
      "CommandTimeoutSeconds": 30,
      "MaxRetryCount": 3,
      "MaxRetryDelaySeconds": 10
    },
    "EventBus": {
      "ConcurrentMessageLimit": 4,
      "PrefetchMultiplier": 4,
      "MinimumPrefetchCount": 4,
      "RetryLimit": 3,
      "RetryInitialSeconds": 1,
      "RetryIncrementSeconds": 2,
      "HostStartTimeoutSeconds": 30,
      "HostStopTimeoutSeconds": 30,
      "EndpointPrefix": ""
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost",
      "http://127.0.0.1",
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  },
  "ForwardedHeaders": {
    "Enabled": false,
    "ForwardLimit": 1,
    "KnownProxies": [],
    "KnownNetworks": []
  },
  "RateLimiting": {
    "GeneralApi": {
      "PermitLimit": 300,
      "QueueLimit": 0,
      "WindowSeconds": 60
    },
    "PasswordLogin": {
      "PermitLimit": 10,
      "QueueLimit": 0,
      "WindowSeconds": 60
    },
    "Refresh": {
      "PermitLimit": 60,
      "QueueLimit": 0,
      "WindowSeconds": 60
    },
    "EdgeOperatorLogin": {
      "PermitLimit": 20,
      "QueueLimit": 0,
      "WindowSeconds": 60
    },
    "Bootstrap": {
      "PermitLimit": 30,
      "QueueLimit": 0,
      "WindowSeconds": 60
    },
    "AiRead": {
      "PermitLimit": 60,
      "QueueLimit": 0,
      "WindowSeconds": 60
    },
    "CapacityUpload": {
      "TokenLimit": 120,
      "TokensPerPeriod": 120,
      "QueueLimit": 0,
      "ReplenishmentPeriodSeconds": 60
    },
    "DeviceLogUpload": {
      "TokenLimit": 120,
      "TokensPerPeriod": 120,
      "QueueLimit": 0,
      "ReplenishmentPeriodSeconds": 60
    },
    "PassStationUpload": {
      "TokenLimit": 600,
      "TokensPerPeriod": 600,
      "QueueLimit": 0,
      "ReplenishmentPeriodSeconds": 60
    },
    "EdgeHostPlcStateUpload": {
      "TokenLimit": 120,
      "TokensPerPeriod": 120,
      "QueueLimit": 0,
      "ReplenishmentPeriodSeconds": 60
    }
  }
}
