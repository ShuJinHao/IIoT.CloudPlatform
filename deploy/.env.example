# Image coordinates
IIOT_HTTPAPI_IMAGE=ghcr.io/example/iiot-httpapi:latest
IIOT_GATEWAY_IMAGE=ghcr.io/example/iiot-gateway:latest
IIOT_DATAWORKER_IMAGE=ghcr.io/example/iiot-dataworker:latest
IIOT_MIGRATION_IMAGE=ghcr.io/example/iiot-migrationworkapp:latest
IIOT_WEB_IMAGE=ghcr.io/example/iiot-web:latest

# Base infrastructure images
IIOT_NGINX_IMAGE=nginx:1.27-alpine
IIOT_POSTGRES_IMAGE=timescale/timescaledb:latest-pg17
IIOT_REDIS_IMAGE=redis:7.4-alpine
IIOT_RABBITMQ_IMAGE=rabbitmq:3-management-alpine
IIOT_SEQ_IMAGE=datalust/seq:2024.3

# Public entrypoint
PUBLIC_BASE_URL=http://10.0.0.15
GATEWAY_HTTP_PORT=80

# Optional loopback-only ops ports
SEQ_HOST_PORT=5341
RABBITMQ_MANAGEMENT_PORT=15672

# Core secrets
PG_PASSWORD=change-me-postgres-password
RABBITMQ_DEFAULT_USER=iiot
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq-password
JWTSETTINGS__SECRET=change-me-jwt-secret
SEQ_ADMIN_PASSWORD=change-me-seq-password

# Seed admin for first boot
SEED_ADMIN_NO=admin
SEED_ADMIN_PASSWORD=change-me-admin-password

# Forwarded headers
FORWARDED_HEADERS_ENABLED=true
FORWARDED_HEADERS_FORWARDLIMIT=2
FORWARDED_HEADERS_KNOWNNETWORKS__0=172.16.0.0/12
FORWARDED_HEADERS_KNOWNNETWORKS__1=10.0.0.0/8

# Refresh and CORS
CORS_ALLOWED_ORIGIN_0=http://10.0.0.15
CORS_ALLOWED_ORIGIN_1=http://localhost:5173
CORS_ALLOWED_ORIGIN_2=http://127.0.0.1:5173

# Logging
SEQ_SERVER_URL=http://seq
SEQ_API_KEY=

