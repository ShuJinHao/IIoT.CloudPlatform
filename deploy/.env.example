# This file is a template only.
# Real production values are kept in the operator-managed .env
# uploaded to the private deployment server.
# Application images are built and pushed to Harbor by CI or local release work.

# Must replace: Harbor application image repositories for this environment.
# deploy-release.sh rewrites the application tag to the requested sha-* release tag.
IIOT_HTTPAPI_IMAGE=harbor.example.com/iiot/iiot-httpapi:sha-0123456789abcdef
IIOT_GATEWAY_IMAGE=harbor.example.com/iiot/iiot-gateway:sha-0123456789abcdef
IIOT_DATAWORKER_IMAGE=harbor.example.com/iiot/iiot-dataworker:sha-0123456789abcdef
IIOT_MIGRATION_IMAGE=harbor.example.com/iiot/iiot-migrationworkapp:sha-0123456789abcdef
IIOT_WEB_IMAGE=harbor.example.com/iiot/iiot-web:sha-0123456789abcdef

# Template defaults: base infrastructure images.
# The production server cannot rely on Docker Hub; mirror these images into Harbor first.
IIOT_NGINX_IMAGE=harbor.example.com/mirror/nginx:1.27-alpine
IIOT_POSTGRES_IMAGE=harbor.example.com/mirror/timescaledb:latest-pg17
IIOT_REDIS_IMAGE=harbor.example.com/mirror/redis:7.4-alpine
IIOT_RABBITMQ_IMAGE=harbor.example.com/mirror/rabbitmq:3-management-alpine
IIOT_SEQ_IMAGE=harbor.example.com/mirror/seq:2024.3

# Must replace: single-machine public entrypoint
PUBLIC_BASE_URL=http://10.98.90.154:81

# Template defaults: single-machine published ports
GATEWAY_HTTP_PORT=81
SEQ_HOST_PORT=5341
RABBITMQ_MANAGEMENT_PORT=15672

# Template defaults: EdgeClient update packages and installer artifacts.
# Production Edge installer artifacts are published to installers/stable/{version}.
EDGE_UPDATES_DIR=/srv/iiot/edge-updates

# Must replace: runtime secrets
PG_PASSWORD=change-me-postgres-password
RABBITMQ_DEFAULT_USER=iiot
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq-password
JWTSETTINGS__SECRET=change-me-jwt-secret
SEQ_ADMIN_PASSWORD=change-me-seq-password

# Must replace: first-boot seed admin
SEED_ADMIN_NO=admin
SEED_ADMIN_PASSWORD=change-me-admin-password

# Template defaults: forwarded headers for a single reverse proxy on one server
FORWARDED_HEADERS_ENABLED=true
FORWARDED_HEADERS_FORWARDLIMIT=2
FORWARDED_HEADERS_KNOWNNETWORKS__0=172.16.0.0/12
FORWARDED_HEADERS_KNOWNNETWORKS__1=10.0.0.0/8

# Must replace primary browser origin to match PUBLIC_BASE_URL
CORS_ALLOWED_ORIGIN_0=http://10.98.90.154:81

# Template defaults: local development origins can stay enabled
CORS_ALLOWED_ORIGIN_1=http://localhost:5173
CORS_ALLOWED_ORIGIN_2=http://127.0.0.1:5173

# Enable only for isolated intranet HTTP Cloud -> AICopilot OIDC.
ALLOW_INTRANET_HTTP_OIDC=true
OIDC_PROVIDER_ISSUER=http://10.98.90.154:81
AICOPILOT_OIDC_REDIRECT_URI=http://10.98.90.154:82/api/identity/cloud-oidc/callback
AICOPILOT_OIDC_POST_LOGOUT_REDIRECT_URI=http://10.98.90.154:82/login
OIDC_PROVIDER_CERTS_DIR=/srv/iiot-cloud/deploy/certs
OIDC_PROVIDER_SIGNING_CERTIFICATE_PATH=/app/certs/cloud-oidc-signing.pfx
OIDC_PROVIDER_SIGNING_CERTIFICATE_PASSWORD=
VITE_AICOPILOT_CHALLENGE_URL=http://10.98.90.154:82/api/identity/cloud-oidc/challenge

# Optional: prefix RabbitMQ queue names consistently across runtime and ops scripts
Infrastructure__EventBus__EndpointPrefix=

# Production sizing defaults for a 16GB single-machine deployment.
# Keep headroom for the OS, Docker, backups, and the AICopilot stack when it runs on the same server.
POSTGRES_MEM_LIMIT=4g
POSTGRES_CPUS=2.0
HTTPAPI_MEM_LIMIT=1536m
HTTPAPI_CPUS=1.5
DATAWORKER_MEM_LIMIT=1536m
DATAWORKER_CPUS=2.0
RABBITMQ_MEM_LIMIT=1g
RABBITMQ_CPUS=1.0
REDIS_MEM_LIMIT=512m
REDIS_CPUS=0.5
GATEWAY_MEM_LIMIT=512m
GATEWAY_CPUS=0.5
SEQ_MEM_LIMIT=512m
SEQ_CPUS=0.5
WEB_MEM_LIMIT=256m
WEB_CPUS=0.25
NGINX_MEM_LIMIT=256m
NGINX_CPUS=0.5

# Production throughput defaults for real-time Edge uploads.
POSTGRES_ENABLE_RETRY=true
EVENTBUS_CONCURRENT_MESSAGE_LIMIT=16
EVENTBUS_PREFETCH_MULTIPLIER=4
PASS_STATION_CONSUMER_CONCURRENCY=16
DEVICE_LOG_CONSUMER_CONCURRENCY=8
HOURLY_CAPACITY_CONSUMER_CONCURRENCY=4
OUTBOX_BATCH_SIZE=500
OUTBOX_POLLING_INTERVAL_SECONDS=1
RATE_LIMIT_CAPACITY_UPLOAD_TOKEN_LIMIT=600
RATE_LIMIT_CAPACITY_UPLOAD_TOKENS_PER_PERIOD=600
RATE_LIMIT_DEVICE_LOG_UPLOAD_TOKEN_LIMIT=600
RATE_LIMIT_DEVICE_LOG_UPLOAD_TOKENS_PER_PERIOD=600
RATE_LIMIT_PASS_STATION_UPLOAD_TOKEN_LIMIT=3000
RATE_LIMIT_PASS_STATION_UPLOAD_TOKENS_PER_PERIOD=3000

# Bootstrap secret enforcement.
# EdgeClient must store and send X-IIoT-Bootstrap-Secret during device bootstrap.
BOOTSTRAP_AUTH_REQUIRE_SECRET=true

# Template defaults: single-machine backup retention and freshness windows
BACKUP_RETENTION_DAYS=14
BACKUP_MAX_AGE_HOURS=24
BACKUP_VERIFY_MAX_AGE_DAYS=7

# Logging
SEQ_SERVER_URL=http://seq

# Optional: leave empty unless Seq ingestion requires an API key
SEQ_API_KEY=
